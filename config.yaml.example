api:
  url: "http://your-llm-api/v1/chat/completions"
  key: "your-api-key"
  model: "your-model-name"

agent:
  model: "minimax/minimax-m2.5"
  provider: "your-provider"

local_llm:
  repo: "mlx-community/Qwen3-1.7B-4bit"
  server_host: "127.0.0.1"
  server_port: 8766

whisper:
  model: "mlx-community/whisper-small-mlx"

tts:
  engine: edge
  qwen_repo: "mlx-community/Qwen3-TTS-12Hz-0.6B-Base-4bit"

vision:
  model: "/Users/you/.cache/mlx-models/MiniCPM-o-4_5-mlx-4bit"
  preload: false
  imagesnap: "/opt/homebrew/bin/imagesnap"
  context_ttl: 60

telegram:
  bot_token: "your-telegram-bot-token"
  chat_id: "your-chat-id"
  bot_enabled: true

audio:
  sample_rate: 16000
  chunk: 480
  channels: 1
  input_device_idx: 1
  silence_after: 0.8
  pre_speech_buf: 0.3
  min_speech_dur: 0.3
  max_record_sec: 10
  noise_cal_sec: 1.0
  speak_cooldown: 0.5
  playback_speed: "1.1"

camera:
  link_ctl: "/opt/homebrew/bin/link-ctl"
  app_name: "Insta360 Link Controller"
  nod_amplitude: 50

conversation:
  ttl: 120
  history_max: 50

proxy:
  http: ""
  https: ""

paths:
  extra:
    - "/opt/homebrew/bin"

output:
  dir: "output"
  retention_days: 90

wake_word:
  agent: "龙虾"

dashboard:
  port: 8765
  enabled: true

location_override: ""
